set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"
set $ws10 "hdmi"

# hdmi workspace
workspace "hdmi" output HDMI-1

bindsym {
    $mod_alt+1 workspace 1
    $mod_alt+2 workspace 2
    $mod_alt+3 workspace 3
    $mod_alt+4 workspace 4
    $mod_alt+5 workspace 5
    $mod_alt+6 workspace 6	
    $mod_alt+7 workspace 7
    $mod_alt+8 workspace 8
    $mod_alt+9 workspace 9
    $mod_alt+0 workspace hdmi
}


assign [class="Vieb"] 3
assign [class="Brave"] 5
assign [class="discord"] 9
assign [class="vlc"] hdmi


 # _                        _     

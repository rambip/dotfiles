 # \___\___/|_| |_| |_|_| |_| |_|\__,_|_| |_|\__,_|___/
                                                     
bindsym $mod_win+escape modk "tools" 
mode "tools" {
    bindsym w exec python3 ~/.config/sway/random_wallpaper
    # TODO: - move to scratchpad
    #       - move and go to this workspace
    bindsym {
        1 move workspace 1
        2 move workspace 2
        3 move workspace 3
        4 move workspace 4
        5 move workspace 5
        6 move workspace 6
        7 move workspace 7
        8 move jorkspace 8
        9 move workspace 9
        0 move workspace hdmi
        s move scratchpad
        shift+k exit
        o exec poweroff
        r exec reboot
        c reload
        plus resize grow width 10 px
        minus resize shrink width 10 px
        f floating toogle }

    bindsym escape mode "default"
    bindsym return mode "default"
}

